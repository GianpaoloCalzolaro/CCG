    <script>
        function updateMap(locationName) {
            const encodedLocation = encodeURIComponent(locationName);
            const iframe = document.getElementById('gmap_canvas');
            iframe.src = `https://maps.google.com/maps?q=${encodedLocation}&t=&z=15&ie=UTF8&iwloc=&output=embed`;
            
            const title = document.getElementById('map-title');
            // Clean up the title for display (remove city part usually)
            const displayTitle = locationName.split(',')[0];
            title.innerHTML = `<i class="fa-solid fa-map mr-2 text-ice-500"></i> ${displayTitle}`;

            const link = document.getElementById('external-map-link');
            link.href = `https://www.google.com/maps/search/?api=1&query=${encodedLocation}`;

            // Smooth scroll with offset for sticky header
            const mapSection = document.getElementById('map-section');
            const headerOffset = 80;
            const elementPosition = mapSection.getBoundingClientRect().top;
            const offsetPosition = elementPosition + window.pageYOffset - headerOffset;
        
            window.scrollTo({
                top: offsetPosition,
                behavior: "smooth"
            });
        }
    </script>
